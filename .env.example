# JulesOps Server — Environment Variables
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
# Set to the frontend URL if serving dashboard from a different origin:
# CORS_ORIGIN=https://your-dashboard.example.com

# ─── Postgres database ────────────────────────────────────────────────────────
# Required for durable storage. If not set, the server falls back to JSON-file demo mode.
# DATABASE_URL=postgres://user:password@localhost:5432/julesops
# PGSSLMODE=require              # set to 'require' for production/Neon/RDS
# PG_POOL_MAX=10                 # connection pool size
# PG_LOG_QUERIES=false           # set to 'true' for query-level logging

# ─── GitHub App ───────────────────────────────────────────────────────────────
# Required to receive and process GitHub App webhooks.
# GITHUB_APP_ID=123456
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Private key — use ONE of the two options below:
# Option A: inline PEM (newlines escaped as \n for env-var storage)
# GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----
# Option B: path to a .pem file on disk
# GITHUB_PRIVATE_KEY_PATH=./keys/julesops-app.pem

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Required for dashboard login via GitHub OAuth.
# GITHUB_OAUTH_CLIENT_ID=Iv1.abc123
# GITHUB_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# APP_BASE_URL=http://localhost:3000

# ─── Session ──────────────────────────────────────────────────────────────────
# SESSION_SECRET=a-long-random-string-minimum-32-chars
# SESSION_COOKIE=julesops_sid
# SESSION_TTL_MS=86400000       # 24 hours in ms

# ─── Stripe billing ───────────────────────────────────────────────────────────
# Required for paid plan checkout and webhook handling.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...

# ─── Alert worker ─────────────────────────────────────────────────────────────
# ALERT_WORKER_ENABLED=true     # set to 'false' to disable the background alert worker
# ALERT_STALE_HOURS=24          # hours before a job is considered stale
# ALERT_INTERVAL_MS=900000      # 15 minutes between alert checks

# ─── Alert email delivery ────────────────────────────────────────────────────
# Set these to send real email alerts through SendGrid.
# SENDGRID_API_KEY=SG.xxxxx
# ALERT_EMAIL_FROM=alerts@example.com
# ALERT_EMAIL_FROM_NAME=JulesOps
# ALERT_EMAIL_REPLY_TO=support@example.com
# ALERT_EMAIL_SUBJECT_PREFIX=JulesOps Alert       # prefix for alert email subject lines
# SENDGRID_API_BASE_URL=https://api.sendgrid.com  # override for tests or alternative endpoints
# ALERT_EMAIL_DEMO_FALLBACK=true                  # keep demo logging enabled when email is not configured

# ─── Local dev webhook tunnel ─────────────────────────────────────────────────
# Use smee or ngrok to receive GitHub webhooks locally (see docs/local-webhook-dev.md)
# JULESOPS_DATA_DIR=./server/data  # JSON store path (demo mode only)
